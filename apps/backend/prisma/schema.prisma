generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ItemType {
  FILE
  FOLDER
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  fileItems    FileItem[]
}

model FileItem {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  type           ItemType
  parentId       String?
  parent         FileItem?   @relation("FolderChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children       FileItem[]  @relation("FolderChildren")
  diskPath       String?
  mimeType       String?
  size           Int         @default(0)
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  shareLinks     ShareLink[]

  @@index([userId, parentId])
  @@index([userId, deletedAt])
}

model ShareLink {
  id           String   @id @default(cuid())
  fileId       String
  file         FileItem @relation(fields: [fileId], references: [id], onDelete: Cascade)
  token        String   @unique
  passwordHash String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
}
